{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RateLimiting": {
    "PermitLimit": 50,
    "QueueLimit": 10,
    "FixedWindowSeconds": 10
  },
  "ReverseProxy": {
    "Routes": {
      "identity-auth": {
        "ClusterId": "identity-cluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/api/v1/auth/{**catch-all}"
        }
      },
      "identity-users": {
        "ClusterId": "identity-cluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/api/v1/users/{**catch-all}"
        }
      },
      "identity-admin": {
        "ClusterId": "identity-cluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/api/v1/admin/{**catch-all}"
        }
      },
      "catalog-events": {
        "ClusterId": "catalog-cluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/api/v1/events/{**catch-all}"
        }
      },
      "booking-reservations": {
        "ClusterId": "booking-cluster",
        "RateLimiterPolicy": "fixed",
        "Match": {
          "Path": "/api/v1/reservations/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5001"
          }
        }
      },
      "catalog-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5002"
          }
        }
      },
      "booking-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5003"
          }
        }
      }
    }
  }
}