# infra/docker/.env — Docker Compose bu dosyayı okur (${DEĞİŞKEN} yerine koyar).
# Değerlerinde `$` kullanma; literal için `$$`.

# PostgreSQL süper kullanıcı parolası
POSTGRES_PASSWORD=ticketflow-dev-local

# Redis konteyneri (--requirepass); TICKETFLOW_REDIS_CONNECTION ile aynı parolayı kullan
REDIS_PASSWORD=ticketflow-redis-dev-change-me

# Bitnami Kafka: SASL/PLAIN istemci kullanıcı ve parola (virgülle çoklu; sıra eşleşmeli)
KAFKA_CLIENT_USERS=ticketflow
KAFKA_CLIENT_PASSWORDS=ticketflow-kafka-dev-change-me
SEQ_ADMIN_PASSWORD=ticketflow-seq-admin-dev-change-me

# Backend / araçlar (bağlantı örnekleri; yukarıdaki parolalarla uyumlu)
TICKETFLOW_REDIS_CONNECTION=localhost:6379,password=ticketflow-redis-dev-change-me,abortConnect=false
TICKETFLOW_KAFKA_BOOTSTRAP=localhost:9092
TICKETFLOW_KAFKA_SECURITY_PROTOCOL=SASL_PLAINTEXT
TICKETFLOW_KAFKA_SASL_MECHANISM=PLAIN
TICKETFLOW_KAFKA_SASL_USERNAME=ticketflow
TICKETFLOW_KAFKA_SASL_PASSWORD=ticketflow-kafka-dev-change-me

# Catalog → Booking iç HTTP (Compose içinde `$` yok)
INTERNAL_SERVICE_KEY=dev-internal-key-change-me
